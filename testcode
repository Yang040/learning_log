import json
def do_login(username,password):
    if username=='admin' and password=="123":
        return "login successful"
    elif username!="admin":
        return "username is wrong"
    else:
        return "password is wrong"
def run_login_test_from_file(filename):
    passed_cases=0
    failed_cases=0
    try:
        with open(filename,"r",encoding='utf-8') as f:
            data=json.load(f)
    except FileNotFoundError:
        print("测试文件不存在,请检查路径")
        return (0,0)
    except json.JSONDecodeError:
        print("测试数据文件格式错误,请检查json格式")
        return (0,0)
    for case in data:
        result=do_login(case['username'],case['password'])
        try:
            print(f"用例编号:{case['case_id']},结果:{result},预期结果:{case['expected']}")
        except KeyError:
            print("用例数据缺少必要字段,跳过该用例")
            failed_cases+=1
            continue
        if result==case['expected']:
            passed_cases+=1
        else:
            failed_cases+=1
    return passed_cases,failed_cases
passed_cases,failed_cases=run_login_test_from_file("test_data.json")
