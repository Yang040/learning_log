import json
def do_login(username,password):
    if username=='admin' and password=="123":
        return "login successful"
    elif username!="admin":
        return "username is wrong"
    else:
        return "password is wrong"
test_result=[]
def safe_run_tests(filename):
    passed_cases=0
    failed_cases=0
    try:
        with open(filename,"r",encoding='utf-8') as f:
            data=json.load(f)
    except FileNotFoundError:
        print("测试文件不存在,请检查路径")
        return (0,0)
    except json.JSONDecodeError:
        print("测试数据文件格式错误,请检查json格式")
        return (0,0)
    for case in data:
        result=do_login(case['username'],case['password'])
        
        try:
            print(f"用例编号:{case['case_id']},结果:{result},预期结果:{case['expected']}")
        except KeyError:
            print("用例数据缺少必要字段,跳过该用例")
            failed_cases+=1
            continue
        if result==case['expected']:
            passed_cases+=1
            status="pass"
        else:
            failed_cases+=1
            status="fail"
        test_result.append({"case_id":case['case_id'],"result":status,"actual":result})
    with open("test_result.json", "w", encoding="utf-8") as f:
        json.dump(test_result, f, ensure_ascii=False, indent=4)
    return passed_cases,failed_cases
passed_cases,failed_cases=safe_run_tests("test_data.json")
print("====统计====")
print(f"通过:{passed_cases},失败:{failed_cases}") 
